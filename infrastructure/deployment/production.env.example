# NRT AI Operations Manager - Production Environment Template

# Core Environment
NODE_ENV=production
PORT=3001

# PostgreSQL Configuration
POSTGRES_USER=nrt_admin
POSTGRES_PASSWORD=CHANGE_THIS_SECURE_PASSWORD!
POSTGRES_DB=nrt_ops_db
DATABASE_URL=postgresql://nrt_admin:CHANGE_THIS_SECURE_PASSWORD!@postgres:5432/nrt_ops_db?schema=public

# Security & JWT
JWT_SECRET=GENERATE_RANDOM_64_CHAR_HEX_STRING
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_SECRET=GENERATE_ANOTHER_RANDOM_HEX_STRING

# AI Provider Keys
OPENAI_API_KEY=sk-proj-YOUR_ACTUAL_OPENAI_KEY
AI_PROVIDER=openai

# URLs
NEXT_PUBLIC_API_URL=https://app.nrtaiops.com
